{
  "name": "spaces",
  "displayName": "Spaces",
  "description": "AI Workspace and Agent Platform.",
  "slogan": "AI Agent & Project Workspace — deploy in one click",
  "tags": ["ai", "agents", "llm", "workspace"],
  "minVersion": "4.x",
  "services": [
    {
      "name": "spaces",
      "ports": ["3000:3000"],
      "volumes": [
        {
          "mountPath": "/app/data",
          "description": "Persistent workspace data (sessions, repos, uploads)"
        }
      ],
      "healthcheck": {
        "test": ["CMD", "wget", "-qO-", "http://localhost:3000/api/health"],
        "interval": "30s",
        "timeout": "3s",
        "startPeriod": "10s",
        "retries": 3
      },
      "environment": [
        {
          "key": "BETTER_AUTH_SECRET",
          "description": "Better Auth Secret. Generate with: openssl rand -base64 32",
          "required": true,
          "generator": "secret"
        },
        {
          "key": "BETTER_AUTH_URL",
          "description": "Public URL of the application",
          "required": false,
          "default": ""
        },
        {
          "key": "OPENAI_API_KEY",
          "description": "OpenAI API key. Optional.",
          "required": false,
          "default": ""
        },
        {
          "key": "ANTHROPIC_API_KEY",
          "description": "Anthropic API key. Optional.",
          "required": false,
          "default": ""
        }
      ]
    }
  ]
}
